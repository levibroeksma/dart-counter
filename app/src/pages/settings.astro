---
import AppLayout from "@layouts/AppLayout.astro";
import DisplayNameSetting from "@components/settings/DisplayNameSetting.astro";
import { getPreferences } from "@lib/server/data/preferences";

let initialDisplayName = "";

try {
  const prefs = await getPreferences();
  initialDisplayName = prefs.displayName ?? "";
} catch {
  initialDisplayName = "";
}
---

<AppLayout>
  <main class="mx-auto w-full max-w-2xl flex-1 p-4 @sm:p-6">
    <header class="mb-6 space-y-1">
      <h1 class="text-text-primary text-2xl font-semibold">Settings</h1>
      <p class="text-text-muted text-sm">Manage your account preferences.</p>
    </header>
    <DisplayNameSetting initialDisplayName={initialDisplayName} />
  </main>
</AppLayout>
