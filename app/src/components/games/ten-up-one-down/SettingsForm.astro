---
import {
  DEFAULT_PLAYTIME_SECONDS,
  DEFAULT_ROUND_COUNT,
  MAX_PLAYTIME_SECONDS,
  MAX_ROUND_COUNT,
  MIN_PLAYTIME_SECONDS,
  MIN_ROUND_COUNT,
} from "@lib/shared/games/ten-up-one-down/constants";
---

<fieldset class="space-y-2">
  <legend class="text-text-muted text-sm">End mode</legend>
  <label class="flex items-center gap-2">
    <input type="radio" name="endMode" value="rounds" x-model="endMode" />
    <span>Rounds</span>
  </label>
  <label class="flex items-center gap-2">
    <input type="radio" name="endMode" value="timed" x-model="endMode" />
    <span>Timed</span>
  </label>
</fieldset>

<label class="block space-y-1" x-show="endMode === 'rounds'">
  <span class="text-text-muted text-sm">Number of rounds</span>
  <input
    type="number"
    name="roundCount"
    value={DEFAULT_ROUND_COUNT}
    min={MIN_ROUND_COUNT}
    max={MAX_ROUND_COUNT}
    class="input w-full"
  />
</label>

<label class="block space-y-1" x-show="endMode === 'timed'" x-cloak>
  <span class="text-text-muted text-sm">Play time (seconds)</span>
  <input
    type="number"
    name="playtimeSeconds"
    value={DEFAULT_PLAYTIME_SECONDS}
    min={MIN_PLAYTIME_SECONDS}
    max={MAX_PLAYTIME_SECONDS}
    step="60"
    class="input w-full"
  />
</label>
