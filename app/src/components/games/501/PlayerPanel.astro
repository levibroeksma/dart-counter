---
import SummaryStatRow from "../SummaryStatRow.astro";

interface Props {
  playerId: string;
  nameModel: string;
  activeExpr: string;
  remainingModel: string;
  checkoutHintModel: string;
  threeDartAverageModel: string;
  lastScoreModel: string;
  dartsModel: string;
}

const {
  playerId,
  nameModel,
  activeExpr,
  remainingModel,
  checkoutHintModel,
  threeDartAverageModel,
  lastScoreModel,
  dartsModel,
} = Astro.props;
---

<article
  class="game-panel flex flex-col gap-2 p-4 transition-colors"
  :class={`(${activeExpr}) ? 'border-accent bg-accent/10' : 'opacity-50'`}
  data-player-id={playerId}
>
  <p class="text-sm text-text-muted" x-text={nameModel}>Player</p>
  <p class="text-4xl font-bold font-mono leading-none" x-text={remainingModel}>501</p>
  <p class="text-sm text-text-muted min-h-5" x-show={checkoutHintModel} x-text={checkoutHintModel} x-cloak>
  </p>

  <dl class="mt-2 flex flex-col gap-1">
    <SummaryStatRow label="3-dart avg" value={threeDartAverageModel} />
    <SummaryStatRow label="Last score" value={lastScoreModel} />
    <SummaryStatRow label="Darts" value={dartsModel} />
  </dl>
</article>
