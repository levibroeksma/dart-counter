---
import UserMenu from "@components/auth/UserMenu.astro";
import IconBtn from "@components/ui/IconBtn.astro";
import LeaveIcon from "@icons/leave.svg";

interface Props {
  title?: string;
  description?: string;
  backHref?: string;
}

const { title, description, backHref } = Astro.props;
const hasPageChrome = Boolean(title || description);
---

<header
  role="banner"
  class="bg-background/80 z-20 flex shrink-0 items-center justify-between gap-3 border-b border-border p-4 backdrop-blur-sm"
>
  <div class="flex min-w-0 flex-1 items-center gap-2">
  {
    backHref ? (
      <IconBtn href={backHref} ariaLabel="Go back" class="shrink-0">
        <LeaveIcon class="size-6 rotate-180 text-muted-foreground" />
      </IconBtn>
    ) : null
  }
  {
    hasPageChrome ? (
      <div class="min-w-0">
        {title ? (
          <h1 class="text-foreground truncate text-lg font-semibold leading-tight">{title}</h1>
        ) : null}
        {description ? (
          <p class="text-muted-foreground truncate text-xs">{description}</p>
        ) : null}
      </div>
    ) : null
  }
  </div>
  <UserMenu />
</header>
