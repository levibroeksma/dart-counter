---
import Input from "@components/ui/Input.astro";
import RadioCard from "@components/ui/RadioCard.astro";
import PlayerPicker from "@components/games/501/PlayerPicker.astro";
---

<fieldset class="space-y-3">
  <legend class="section-label">Players</legend>
  <p class="text-xs text-text-muted">Play solo or add one guest player.</p>
  <PlayerPicker />
</fieldset>

<fieldset class="space-y-3">
  <legend class="section-label">Match format</legend>
  <div class="flex flex-col gap-3 @sm:flex-row @sm:items-end">
    <fieldset class="flex gap-3 flex-1">
      <RadioCard
        name="matchMode"
        value="best-of"
        title="Best of"
        checked
        x-model="matchMode"
      />
      <RadioCard
        name="matchMode"
        value="first-to"
        title="First to"
        x-model="matchMode"
      />
    </fieldset>
    <Input
      id="target-count"
      name="targetCount"
      label=" "
      type="number"
      value={3}
      min={1}
      max={11}
      class="w-20"
    />
    <fieldset class="flex gap-3 flex-1">
      <RadioCard
        name="unit"
        value="legs"
        title="Legs"
        checked
        x-model="unit"
      />
      <RadioCard
        name="unit"
        value="sets"
        title="Sets"
        x-model="unit"
      />
    </fieldset>
  </div>
</fieldset>
