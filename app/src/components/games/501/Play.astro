---
import NumberInputPad from "@components/ui/NumberInputPad.astro";
import OptionModal from "@components/ui/OptionModal.astro";
import type { FiveOhOneSession } from "@lib/shared/games/501";
import LeaveIcon from "@icons/leave.svg";
import DartBotTurnModal from "./DartBotTurnModal.astro";
import PlayerPanel from "./PlayerPanel.astro";
import PlayShellSkeleton from "./PlayShellSkeleton.astro";
import StarterScreen from "./StarterScreen.astro";
import Summary from "./Summary.astro";

interface Props {
  displayName: string;
  gameSession?: FiveOhOneSession | null;
}

const { displayName, gameSession = null } = Astro.props;
const sessionJson = JSON.stringify(gameSession ?? null).replace(/</g, "\\u003c");
const firstPlayerId = gameSession?.settings.players[0]?.id ?? "";
const secondPlayerId = gameSession?.settings.players[1]?.id ?? "";
const playerName = (playerId: string) =>
  `formatPlayerName(session?.settings.players.find((player) => player.id === '${playerId}') ?? { type: 'guest', id: '', name: '' })`;
---

<section
  class="relative flex-1 h-full flex flex-col gap-4"
  x-data={`fiveOhOnePlay(${sessionJson})`}
  x-init="init()"
  :aria-busy="!ready || (showSummary && !summary)"
>
  <div class="flex justify-between py-2">
    <button type="button" class="btn-press" @click="leave()">
      <LeaveIcon class="size-6 text-text-muted rotate-180" />
    </button>
  <h2
    class="text-lg font-mono font-semibold uppercase"
    x-text="matchFormatLabelDisplay()"
    x-show="ready"
    x-cloak
  ></h2>
    <div class="size-6 transparent"></div>
  </div>

  <div x-show="!ready">
    <PlayShellSkeleton />
  </div>

  <div x-show="ready && !showSummary" x-cloak class="flex flex-col gap-4 flex-1">


    <StarterScreen
      x-show="session?.settings.players.length === 2 && session?.state.phase === 'starter'"
      firstPlayerId={firstPlayerId}
      firstNameModel={playerName(firstPlayerId)}
      secondPlayerId={secondPlayerId}
      secondNameModel={playerName(secondPlayerId)}
    />

    <div x-show="session?.state.phase === 'play'" x-cloak class="flex flex-col gap-4 flex-1">
      <div x-show="session?.settings.players.length === 1" x-cloak>
        <PlayerPanel
          playerId={firstPlayerId}
          nameModel={playerName(firstPlayerId)}
          activeExpr="true"
          remainingModel={`String(session?.state.players.find((player) => player.playerId === '${firstPlayerId}')?.remaining ?? 0)`}
          checkoutHintModel={`checkoutHintDisplay('${firstPlayerId}')`}
          threeDartAverageModel={`threeDartAverageDisplay('${firstPlayerId}')`}
          lastScoreModel={`lastScoreDisplay('${firstPlayerId}')`}
          dartsModel={`dartsDisplay('${firstPlayerId}')`}
        />
      </div>

      <div x-show="session?.settings.players.length === 2" x-cloak class="grid grid-cols-2 gap-3">
        <PlayerPanel
          playerId={firstPlayerId}
          nameModel={playerName(firstPlayerId)}
          activeExpr={`session?.state.currentPlayerId === '${firstPlayerId}'`}
          remainingModel={`String(session?.state.players.find((player) => player.playerId === '${firstPlayerId}')?.remaining ?? 0)`}
          checkoutHintModel={`checkoutHintDisplay('${firstPlayerId}')`}
          threeDartAverageModel={`threeDartAverageDisplay('${firstPlayerId}')`}
          lastScoreModel={`lastScoreDisplay('${firstPlayerId}')`}
          dartsModel={`dartsDisplay('${firstPlayerId}')`}
        />
        <PlayerPanel
          playerId={secondPlayerId}
          nameModel={playerName(secondPlayerId)}
          activeExpr={`session?.state.currentPlayerId === '${secondPlayerId}'`}
          remainingModel={`String(session?.state.players.find((player) => player.playerId === '${secondPlayerId}')?.remaining ?? 0)`}
          checkoutHintModel={`checkoutHintDisplay('${secondPlayerId}')`}
          threeDartAverageModel={`threeDartAverageDisplay('${secondPlayerId}')`}
          lastScoreModel={`lastScoreDisplay('${secondPlayerId}')`}
          dartsModel={`dartsDisplay('${secondPlayerId}')`}
        />
      </div>

      <article class="game-panel flex-1 p-4 flex flex-col">
        <NumberInputPad
          scoreModel="score"
          submitAction="submitVisit()"
          disabledExpr="controlsDisabled"
          canUndoExpr="canUndo"
          undoAction="undoVisit()"
        />
      </article>

      <OptionModal
        openModel="showModal"
        submitAction="modalSubmit()"
        submitDisabledExpr="!modalCanSubmit || persisting"
        closeAction="closeModal()"
      >
        <template x-for="question in modalQuestions" :key="question.id">
          <div x-show="question.autoValue === undefined" class="mb-4">
            <h3 class="section-label" x-text="question.label"></h3>
            <div class="flex items-center justify-center gap-2">
              <template x-for="n in question.options" :key="n">
                <button
                  type="button"
                  class="card-interactive btn-press justify-center text-sm text-center"
                  @click="question.id === 'dartsOnDouble' ? dartsOnDouble = n : dartsForFinish = n"
                  :class="(question.id === 'dartsOnDouble' ? dartsOnDouble : dartsForFinish) === n ? 'bg-accent text-accent-foreground' : ''"
                  x-text="n"
                ></button>
              </template>
            </div>
          </div>
        </template>
      </OptionModal>
    </div>
  </div>

  <DartBotTurnModal
    openModel="botModalOpen"
    segmentLabelModel="botModalSegmentLabel"
    dartLabelsModel="botModalDartLabels"
    skipAction="skipDartBotTurnAnimation()"
  />
  <Summary showSummaryModel="showSummary && summary" persistingModel="persisting" />
  <p x-show="error" x-cloak x-text="error" class="text-sm text-red-400" role="alert"></p>
</section>
