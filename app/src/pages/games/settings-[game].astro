---
import AppLayout from "@layouts/AppLayout.astro";
import GameSettingsShell from "@components/games/GameSettingsShell.astro";
import TenUpOneDownSettingsShell from "@components/games/ten-up-one-down/TenUpOneDownSettingsShell.astro";
import ScoreTrainingSettingsShell from "@components/games/score-training/ScoreTrainingSettingsShell.astro";
import SinglesTrainingSettingsShell from "@components/games/singles-training/SinglesTrainingSettingsShell.astro";
import FiveOhOneSettingsShell from "@components/games/501/FiveOhOneSettingsShell.astro";
import { getGameBySlug } from "@lib/server/data/games";
import { getPreferences } from "@lib/server/data/preferences";
import {
  getSettingsFormComponent,
  hasGameComponents,
} from "@lib/shared/games/components";

const { game: slug } = Astro.params;

if (!slug) {
  return Astro.redirect("/games?error=unknown-game");
}

const game = await getGameBySlug(slug);
if (!game) {
  return Astro.redirect("/games?error=unknown-game");
}

if (!hasGameComponents(slug)) {
  return Astro.redirect("/games?error=unavailable-game");
}

const SettingsForm = getSettingsFormComponent(slug)!;

const session = Astro.locals.session!;
const userId = session.userId ?? "";
let displayName = "You";

if (slug === "501" && userId) {
  const preferences = await getPreferences(userId);
  displayName = preferences.displayName?.trim() || displayName;
}
---

<AppLayout
  title={game.displayName}
  description="Configure your game settings."
  backHref="/games"
>
  {
    slug === "ten-up-one-down" ? (
      <TenUpOneDownSettingsShell game={game}>
        <SettingsForm />
      </TenUpOneDownSettingsShell>
    ) : slug === "score-training" ? (
      <ScoreTrainingSettingsShell game={game}>
        <SettingsForm />
      </ScoreTrainingSettingsShell>
    ) : slug === "singles-training" ? (
      <SinglesTrainingSettingsShell game={game}>
        <SettingsForm />
      </SinglesTrainingSettingsShell>
    ) : slug === "501" ? (
      <FiveOhOneSettingsShell game={game} displayName={displayName} userId={userId}>
        <SettingsForm />
      </FiveOhOneSettingsShell>
    ) : (
      <GameSettingsShell game={game}>
        <SettingsForm />
      </GameSettingsShell>
    )
  }
</AppLayout>
