---
import { ALL_DOUBLES } from "@lib/shared/darts/doubles";

interface Props {
  label: string;
  model: string;
  onSelect: string;
}

const { label, model, onSelect } = Astro.props;
---

<div class="flex w-full flex-col gap-2">
  <h3 class="section-label">{label}</h3>
  <div class="grid grid-cols-5 gap-2">
    {ALL_DOUBLES.map((doubleValue) => (
      <div
        class:list={[
          "card-interactive btn-press justify-center text-xs",
          doubleValue === "Bull" && "col-start-3",
        ]}
        @click={`${onSelect}('${doubleValue}')`}
        :class={`${model} === '${doubleValue}' ? 'bg-accent text-accent-foreground' : ''`}
        :aria-pressed={`${model} === '${doubleValue}'`}
      >
        {doubleValue === "Bull" ? "BULL" : doubleValue}
      </div>
    ))}
  </div>
</div>
