---
interface Props {
  showSummaryModel?: string;
  visitDartLabelsModel?: string;
  isBullTargetModel?: string;
  targetDisplayModel?: string;
  disabledExpr?: string;
  canUndoExpr?: string;
}

const {
  showSummaryModel = "showSummary",
  visitDartLabelsModel = "visitDartLabels",
  isBullTargetModel = "isBullTarget",
  targetDisplayModel = "targetDisplay",
  disabledExpr = "controlsDisabled",
  canUndoExpr = "session.dartHistory.length > 0",
} = Astro.props;

import UndoIcon from "@icons/undo.svg";
---

<div class="flex items-center justify-between divide-x divide-border rounded-md bg-muted/50 p-3">
  <template x-for={`(label, index) in ${visitDartLabelsModel}`} :key="index">
    <div class="w-1/3 text-center" x-text="label"></div>
  </template>
</div>
<article class="game-panel flex flex-col gap-3 flex-1" x-show={`!${showSummaryModel}`} x-cloak>

  <div class="flex flex-col divide-y divide-border  flex-1" x-show={`!${isBullTargetModel}`} x-cloak>
    <div class="rounded-md flex font-bold divide-x divide-border flex-1">
      <button
        type="button"
        class="w-1/3 text-center text-3xl py-6 btn-press flex-1"
        :disabled={disabledExpr}
        @click="submitDart({ type: 'single' })"
        x-text={`'S' + ${targetDisplayModel}`}
      ></button>
      <button
        type="button"
        class="w-1/3 text-center text-3xl py-6 btn-press flex-1"
        :disabled={disabledExpr}
        @click="submitDart({ type: 'double' })"
        x-text={`'D' + ${targetDisplayModel}`}
      ></button>
      <button
        type="button"
        class="w-1/3 text-center text-3xl font-bold py-6 btn-press flex-1"
        :disabled={disabledExpr}
        @click="submitDart({ type: 'triple' })"
        x-text={`'T' + ${targetDisplayModel}`}
      ></button>
    </div>
    <div class="rounded-md flex divide-x divide-border flex-1">
      <button
        type="button"
        class="w-1/2 text-center py-6 btn-press flex-1 flex items-center justify-center"
        :class={`(!(${canUndoExpr}) || ${disabledExpr}) ? 'opacity-50 cursor-not-allowed' : ''`}
        :disabled={`!(${canUndoExpr}) || ${disabledExpr}`}
        @click="undoDart()"
      >
        <UndoIcon class="size-10 text-muted-foreground" />
      </button>
      <button
        type="button"
        class="w-1/2 text-center py-6 btn-press flex-1 uppercase text-3xl font-bold"
        :disabled={disabledExpr}
        @click="submitDart({ type: 'miss' })"
      >
        Miss
      </button>
    </div>
  </div>

  <div class="grid grid-cols-2 divide-x divide-y divide-border rounded-md flex-1" x-cloak x-show={isBullTargetModel}>
    <button
      type="button"
      class="text-center py-6 btn-press font-medium"
      :disabled={disabledExpr}
      @click="submitDart({ type: 'single' })"
    >
      Single
    </button>
    <button
      type="button"
      class="text-center py-6 btn-press font-medium"
      :disabled={disabledExpr}
      @click="submitDart({ type: 'double' })"
    >
      Bull
    </button>
    <button
      type="button"
      class="text-center py-6 btn-press font-medium flex items-center justify-center"
      :class={`(!(${canUndoExpr}) || ${disabledExpr}) ? 'opacity-50 cursor-not-allowed' : ''`}
      :disabled={`!(${canUndoExpr}) || ${disabledExpr}`}
      @click="undoDart()"
    >
      <UndoIcon class="size-10 text-muted-foreground" />
    </button>
    <button
      type="button"
      class="text-center py-6 btn-press font-medium uppercase"
      :disabled={disabledExpr}
      @click="submitDart({ type: 'miss' })"
    >
      Miss
    </button>
  </div>
</article>
