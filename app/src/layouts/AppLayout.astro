---
import BaseLayout from "@layouts/BaseLayout.astro";
import AppHeader from "@components/layout/AppHeader.astro";
import BottomNav from "@components/layout/BottomNav.astro";

interface Props {
  title?: string;
  description?: string;
  backHref?: string;
}

const { title, description, backHref } = Astro.props;
---

<BaseLayout>
  <div class="flex h-full min-h-0 flex-1 touch-manipulation flex-col overflow-hidden">
    <AppHeader title={title} description={description} backHref={backHref} />
    <div class="flex min-h-0 flex-1 flex-col overflow-y-auto overscroll-y-contain">
      <slot />
    </div>
    <BottomNav />
  </div>
</BaseLayout>
