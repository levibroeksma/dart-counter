<div
  x-data="gameToast()"
  x-show="visible"
  x-transition:enter="transition-fade-scale-enter"
  x-transition:enter-start="opacity-0 scale-95 translate-y-2"
  x-transition:enter-end="opacity-100 scale-100 translate-y-0"
  x-transition:leave="transition-fade-scale-leave"
  x-transition:leave-start="opacity-100 scale-100 translate-y-0"
  x-transition:leave-end="opacity-0 scale-95 translate-y-2"
  x-cloak
  role="alert"
  aria-live="polite"
  class="toast-panel fixed bottom-20 left-1/2 z-30 -translate-x-1/2 rounded-lg border border-border bg-surface-elevated px-4 py-3 text-sm text-text-primary shadow-card"
>
  <span x-text="message"></span>
</div>
