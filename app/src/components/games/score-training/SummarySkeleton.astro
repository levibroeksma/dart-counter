---
import Skeleton from "@components/ui/Skeleton.astro";
---

<article class="game-panel p-6 flex flex-col gap-4" data-testid="st-summary-skeleton">
  <h2 class="text-xl font-semibold">Game Complete</h2>
  <dl class="grid grid-cols-2 gap-3">
    <span class="text-muted-foreground">Total score</span>
    <Skeleton variant="text" class="h-3 w-12 justify-self-end" />
    <span class="text-muted-foreground">3-dart average</span>
    <Skeleton variant="text" class="h-3 w-12 justify-self-end" />
    <span class="text-muted-foreground">Rounds played</span>
    <Skeleton variant="text" class="h-3 w-12 justify-self-end" />
    <span class="text-muted-foreground">Darts thrown</span>
    <Skeleton variant="text" class="h-3 w-12 justify-self-end" />
  </dl>
  <h3 class="font-semibold">Do you want to play again?</h3>
  <div class="grid grid-cols-2 gap-3">
    <span class="btn-secondary btn-press font-medium flex items-center justify-center">No</span>
    <span
      class="btn-primary btn-press font-medium flex items-center justify-center opacity-50 cursor-not-allowed"
    >
      Yes
    </span>
  </div>
</article>
