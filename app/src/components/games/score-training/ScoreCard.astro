---
interface Props {
  currentScoreModel?: string;
  threeDartAverageDisplayModel?: string;
  dartsThrownDisplayModel?: string;
  lastScoreDisplayModel?: string;
}

const {
  currentScoreModel = "session.state.currentScore",
  threeDartAverageDisplayModel = "threeDartAverageDisplay",
  dartsThrownDisplayModel = "dartsThrownDisplay",
  lastScoreDisplayModel = "lastScoreDisplay",
} = Astro.props;
---

<article class="game-panel p-3 h-40" data-testid="st-score-card">
  <div class="flex items-center justify-center flex-col gap-4">
    <div class="flex items-center justify-center flex-col gap-2">
      <span class="text-sm text-text-muted font-mono uppercase tracking-wider">Current Score</span>
      <span class="text-4xl font-bold" x-text={currentScoreModel}></span>
    </div>
    <div class="flex items-center justify-center gap-4 text-xs text-text-muted font-mono">
      <span>Avg: <span x-text={threeDartAverageDisplayModel}></span></span>
      <span>Darts: <span x-text={dartsThrownDisplayModel}></span></span>
      <span>Last: <span x-text={lastScoreDisplayModel}></span></span>
    </div>
  </div>
</article>
