---
import { getCheckoutHint } from "@lib/shared/darts/checkouts";

interface Props {
  target?: number;
  targetModel?: string;
}

const { target = 41, targetModel = "session.state.currentTarget" } = Astro.props;
const checkoutHint = getCheckoutHint(target);
---

<article class="game-panel p-3 h-40" data-testid="tuod-target-card">
  <div class="flex items-center justify-center flex-col gap-6">
    <div class="flex items-center justify-center flex-col gap-2">
      <span class="text-sm text-text-muted font-mono uppercase tracking-wider">Target</span>
      <span class="text-4xl font-bold" x-text={targetModel}>{target}</span>
    </div>

    <span class="checkout-hint">
      {checkoutHint?.segments?.length ? (
        checkoutHint.segments.map((segment) => <span>{segment}</span>)
      ) : (
        <span class="text-text-muted">No checkout route</span>
      )}
    </span>
  </div>
</article>
