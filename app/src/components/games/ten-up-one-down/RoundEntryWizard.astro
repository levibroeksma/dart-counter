---
import DartCountPicker from "./DartCountPicker.astro";
import DoubleGrid from "./DoubleGrid.astro";
---

<div class="flex flex-1 w-full flex-col gap-4 overflow-y-auto min-h-0">
  <template x-if="step === 'outcome'">
    <div class="flex flex-1 w-full flex-col justify-center gap-2">
      <span class="text-sm text-text-muted font-mono uppercase tracking-wider">Target hit?</span>
      <div class="grid flex-1 w-full grid-cols-2 gap-2">
        <button type="button" class="card w-full" @click="targetHit = false; wizardNext()">No</button>
        <button type="button" class="card w-full" @click="targetHit = true; wizardNext()">Yes</button>
      </div>
    </div>
  </template>

  <article
    class="flex flex-1 w-full flex-col gap-4 transition-all duration-300"
    x-show="showDartSteps"
    x-cloak
  >
    <template x-if="step === 'dartsUsed'">
      <div>
        <DartCountPicker label="Darts used" options={[1, 2, 3]} model="dartsUsed" />
      </div>
    </template>

    <template x-if="step === 'onDouble' && isSuccess">
      <div>
        <DartCountPicker label="Darts on double" options={[1, 2, 3]} model="onDouble" />
      </div>
    </template>

    <template x-if="step === 'onDouble' && !isSuccess">
      <div>
        <DartCountPicker label="Darts on double" options={[0, 1, 2, 3]} model="onDouble" />
      </div>
    </template>
  </article>

  <article
    class="transition-all duration-300"
    x-show="showDoubleGrid"
    x-transition:enter="transform transition ease-out duration-300"
    x-transition:enter-start="translate-y-4 opacity-0"
    x-transition:enter-end="translate-y-0 opacity-100"
    x-transition:leave="transform transition ease-in duration-200"
    x-transition:leave-start="translate-y-0 opacity-100"
    x-transition:leave-end="translate-y-4 opacity-0"
    x-cloak
  >
    <template x-if="isSuccess">
      <div>
        <DoubleGrid label="Finished on double" model="finishedOnDouble" />
      </div>
    </template>
    <template x-if="!isSuccess">
      <div>
        <DoubleGrid label="Double attempted" model="doubleAttempted" />
      </div>
    </template>
  </article>

  <template x-if="step === 'busted'">
    <div class="flex flex-1 w-full flex-col justify-center gap-2">
      <span class="text-sm text-text-muted font-mono uppercase tracking-wider">Busted?</span>
      <div class="grid w-full grid-cols-2 gap-2">
        <button type="button" class="card w-full" @click="busted = false; wizardNext()">No</button>
        <button type="button" class="card w-full" @click="busted = true; wizardNext()">Yes</button>
      </div>
    </div>
  </template>

  <template x-if="step === 'submit'">
    <button
      type="button"
      class="btn-press w-full rounded-full bg-accent px-4 py-2.5 font-medium text-accent-foreground hover:bg-accent-hover focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring disabled:opacity-70"
      :disabled="loading"
      @click="submit()"
    >
      Submit
    </button>
  </template>

  <button
    type="button"
    class="btn-press w-full rounded-full border border-border px-4 py-2 text-sm"
    x-show="step !== 'outcome'"
    @click="wizardBack()"
  >
    Back
  </button>
</div>
