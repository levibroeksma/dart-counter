<div class="space-y-4" x-show="players.some((player) => player.type === 'dartbot')" x-cloak>
  <label for="dartbot-level" class="section-label">DartBot level</label>
  <div class="space-y-4">
    <input
      id="dartbot-level"
      type="range"
      min="1"
      max="15"
      step="1"
      x-model.number="dartbotLevel"
      class="w-full accent-text-accent"
    />
    <dl class="grid grid-cols-1 gap-x-4 gap-y-1 rounded-md border border-border bg-surface-elevated px-3 py-2">
      <div class="flex justify-between gap-2 text-xs">
        <dt class="text-text-muted">3-dart avg</dt>
        <dd class="font-mono font-semibold text-text-primary" x-text="dartbotLevelPreview.threeDartAverage"></dd>
      </div>
      <div class="flex justify-between gap-2 text-xs">
        <dt class="text-text-muted">Checkout rate</dt>
        <dd class="font-mono font-semibold text-text-primary" x-text="dartbotLevelPreview.checkoutSuccessRate"></dd>
      </div>
    </dl>
  </div>
</div>
