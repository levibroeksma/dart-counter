---
interface Props {
  displayName: string;
  slug: string;
}
const { displayName, slug } = Astro.props;
---
<section class="card space-y-2">
  <p class="text-foreground">Playing {displayName}</p>
  <p class="text-muted-foreground text-sm">Game slug: {slug}</p>
  <p class="text-muted-foreground text-sm">[121 play UI placeholder]</p>
</section>
