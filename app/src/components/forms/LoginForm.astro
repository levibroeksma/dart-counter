---
import Input from "@components/ui/Input.astro";
import PrimaryBtn from "@components/ui/PrimaryBtn.astro";
import { sanitizeRedirect } from "@lib/shared/utils/redirect";

const redirect = sanitizeRedirect(Astro.url.searchParams.get("redirect"));
---

<article class="card @container w-full max-w-sm p-6 @sm:p-8">
  <header class="space-y-2">
    <h1 id="login-heading" class="text-foreground @sm:text-xl font-semibold">
      Dart Counter
    </h1>
    <p class="text-muted-foreground @sm:text-sm leading-relaxed">
      Welcome to your personalized dart counter app, tracking your every step
      of progress towards a higher average.
    </p>
  </header>

  <form
    class="mt-6 space-y-4"
    x-data="loginForm()"
    @submit.prevent="submit"
    data-redirect={redirect}
    aria-labelledby="login-heading"
  >
    <fieldset class="space-y-4 border-0 p-0">
      <legend class="sr-only">Sign in</legend>

      <Input
        id="email"
        name="email"
        label="Email"
        type="email"
        autocomplete="email"
        required
        x-model="email"
      />

      <Input
        id="password"
        name="password"
        label="Password"
        type="password"
        autocomplete="current-password"
        required
        x-model="password"
      />
    </fieldset>

    <PrimaryBtn label="Login" />

    <p
      x-show="error"
      x-text="error"
      x-cloak
      class="text-destructive text-sm"
      role="alert"
      aria-live="polite"
    ></p>
  </form>
</article>
