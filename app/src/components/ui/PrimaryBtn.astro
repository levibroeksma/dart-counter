<button
  type="submit"
  :disabled="loading"
  :aria-busy="loading"
  class="btn-press relative w-full rounded-full bg-accent px-4 py-2.5 font-medium text-accent-foreground hover:bg-accent-hover focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring disabled:opacity-70"
>
  <span x-show="!loading" x-cloak><slot /></span>
  <span x-show="loading" x-cloak class="spinner" aria-hidden="true"></span>
</button>
