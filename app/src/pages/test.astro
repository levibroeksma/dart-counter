---
// Layouts
import AppLayout from "@layouts/AppLayout.astro";

---

<AppLayout>
  <main class="mx-auto w-full max-w-2xl flex-1 p-4 @sm:p-6 space-y-3 border border-red-500">
      <div class="flex flex-col justify-center items-center border border-border rounded-md h-fit gap-4 p-3">
          <div class="flex flex-col items-center justify-center gap-2 flex-1 w-full">
            <span class="text-4xl">0</span>
            <span class="text-sm text-text-muted font-mono uppercase tracking-wider bg-slate-500/20 rounded-md px-2 py-1">Current Score</span>
          </div>
          <div class="flex flex-col text-text-muted font-mono text-xs flex-1 w-full">
            <div class="inline-flex justify-between"><span>Miss</span> <span>0</span></div>
            <div class="inline-flex justify-between"><span>Single</span> <span>0</span></div>
            <div class="inline-flex justify-between"><span>Double</span> <span>0</span></div>
            <div class="inline-flex justify-between"><span>Triple</span> <span>0</span></div>
          </div>
      </div>
      <div class="text-text-muted font-mono text-sm">
        Your target is <span>10</span>
      </div>
      <div class="bg-slate-500/20 rounded-md p-3 flex justify-between items-center divide-x divide-slate-500/20">
          <div class="w-1/3 text-center">
            <!-- placeholder when no value for dart has been thrown -->
             -
          </div>
          <div class="w-1/3 text-center">
            <!-- placeholder when no value for dart has been thrown -->
            -
          </div>

          <div class="w-1/3 text-center">
            <!-- placeholder when no value for dart has been thrown -->
            -
          </div>
      </div>
      <div class="flex flex-col divide-y divide-slate-500/20">
        <div class="rounded-md  flex justify-between items-center divide-x divide-slate-500/20">
          <button type="button" class="w-1/3 text-center py-6">
            <!-- placeholder when no value for dart has been thrown -->
             S10
          </button>
          <button type="button" class="w-1/3 text-center py-6">
            <!-- placeholder when no value for dart has been thrown -->
            D10
          </button>

          <button type="button" class="w-1/3 text-center py-6">
            <!-- placeholder when no value for dart has been thrown -->
            T10
          </button>
      </div>
      <div class="rounded-md flex justify-between items-center divide-x divide-slate-500/20">
          <button type="button" class="w-1/2 text-center py-6">
             Back
          </button>
          <button type="button" class="w-1/2 text-center py-6">
            Miss
          </button>
      </div>
      </div>
  </main>
</AppLayout>
