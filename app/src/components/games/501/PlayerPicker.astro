---
import ProfileIcon from "@icons/profile.svg";
import CrossIcon from "@icons/cross.svg";
---

<div class="flex flex-wrap items-center gap-3">
  <div class="flex items-center gap-2">
    <div class="flex size-10 items-center justify-center rounded-full border border-border bg-surface-elevated text-text-muted">
      <ProfileIcon class="size-5" aria-hidden="true" />
    </div>
    <span class="text-sm font-medium text-text-primary" x-text="players[0]?.name"></span>
  </div>

  <button
    type="button"
    class="btn-press flex size-10 items-center justify-center rounded-full border border-dashed border-border text-lg text-text-muted hover:text-text-primary"
    x-show="!hasGuest"
    @click="openGuestModal()"
    aria-label="Add guest player"
  >
    +
  </button>

  <div class="relative flex items-center gap-2" x-show="hasGuest" x-cloak>
    <div class="relative">
      <div class="flex size-10 items-center justify-center rounded-full border border-border bg-surface-elevated text-sm font-semibold text-text-primary">
        <span x-text="(players.find((player) => player.type === 'guest')?.name?.charAt(0) || '?').toUpperCase()"></span>
      </div>
      <button
        type="button"
        class="btn-press absolute -top-1 -right-1 flex size-5 items-center justify-center rounded-full border border-border bg-surface-elevated text-text-muted hover:text-text-primary"
        @click="removeGuest()"
        aria-label="Remove guest player"
      >
        <CrossIcon class="size-3.5" aria-hidden="true" />
      </button>
    </div>
    <span
      class="text-sm font-medium text-text-primary"
      x-text="players.find((player) => player.type === 'guest')?.name"
    ></span>
  </div>
</div>
