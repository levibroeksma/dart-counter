---
import AppLayout from "@layouts/AppLayout.astro";
import GameSettingsShell from "@components/games/GameSettingsShell.astro";
import TenUpOneDownSettingsShell from "@components/games/ten-up-one-down/TenUpOneDownSettingsShell.astro";
import ScoreTrainingSettingsShell from "@components/games/score-training/ScoreTrainingSettingsShell.astro";
import SinglesTrainingSettingsShell from "@components/games/singles-training/SinglesTrainingSettingsShell.astro";
import { getGameBySlug } from "@lib/server/data/games";
import {
  getSettingsFormComponent,
  hasGameComponents,
} from "@lib/shared/games/components";
import { getTenUpOneDownSession } from "@lib/server/data/ten-up-one-down-session";
import { isTenUpOneDownSession } from "@lib/shared/games/ten-up-one-down/session";
import { getSinglesTrainingSession } from "@lib/server/data/singles-training-session";
import { isSinglesTrainingSession } from "@lib/shared/games/singles-training/session";

const { game: slug } = Astro.params;

if (!slug) {
  return Astro.redirect("/games?error=unknown-game");
}

const game = await getGameBySlug(slug);
if (!game) {
  return Astro.redirect("/games?error=unknown-game");
}

if (!hasGameComponents(slug)) {
  return Astro.redirect("/games?error=unavailable-game");
}

const session = Astro.locals.session!;
const SettingsForm = getSettingsFormComponent(slug)!;
let hasActiveSession = false;

if (slug === "ten-up-one-down" && session.userId) {
  const activeSession = await getTenUpOneDownSession(session.userId);
  hasActiveSession = isTenUpOneDownSession(activeSession);
} else if (slug === "singles-training" && session.userId) {
  const activeSession = await getSinglesTrainingSession(session.userId);
  hasActiveSession = isSinglesTrainingSession(activeSession);
}
---

<AppLayout
  title={game.displayName}
  description="Configure your game settings."
  backHref="/games"
>
  {
    slug === "ten-up-one-down" ? (
      <TenUpOneDownSettingsShell game={game} hasActiveSession={hasActiveSession}>
        <SettingsForm />
      </TenUpOneDownSettingsShell>
    ) : slug === "score-training" ? (
      <ScoreTrainingSettingsShell game={game}>
        <SettingsForm />
      </ScoreTrainingSettingsShell>
    ) : slug === "singles-training" ? (
      <SinglesTrainingSettingsShell game={game} hasActiveSession={hasActiveSession}>
        <SettingsForm />
      </SinglesTrainingSettingsShell>
    ) : (
      <GameSettingsShell game={game}>
        <SettingsForm />
      </GameSettingsShell>
    )
  }
</AppLayout>
