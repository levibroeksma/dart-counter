---
import SummaryStatRow from "../SummaryStatRow.astro";

interface Props {
  showSummaryModel?: string;
  summaryModel?: string;
  persistingModel?: string;
  hasGuestExpr?: string;
}

const {
  showSummaryModel = "showSummary && summary",
  summaryModel = "summary",
  persistingModel = "persisting",
  hasGuestExpr = "session.settings.players.length === 2",
} = Astro.props;
---

<article class="game-panel p-6 flex flex-col gap-6" x-show={showSummaryModel} x-cloak>
  <h2 class="text-2xl font-semibold">Game Complete</h2>

  <dl class="flex flex-col gap-1">
    <SummaryStatRow label="Result" value={`${summaryModel}?.resultLabel ?? ''`} />
    <SummaryStatRow label="Match format" value={`${summaryModel}?.matchFormatLabel ?? ''`} />
    <SummaryStatRow label="Legs played" value={`String(${summaryModel}?.legsPlayed ?? 0)`} />
    <SummaryStatRow
      label="Your 3-dart average"
      value={`(${summaryModel}?.userThreeDartAverage ?? 0).toFixed(1)`}
    />
    <SummaryStatRow label="Your darts thrown" value={`String(${summaryModel}?.userDartsThrown ?? 0)`} />
    <SummaryStatRow label="Checkouts" value={`String(${summaryModel}?.checkouts ?? 0)`} />
    <div class="flex justify-between font-mono" x-show={hasGuestExpr} x-cloak>
      <dt
        class="text-text-muted"
        x-text="`${session?.settings.players.find((player) => player.type !== 'user')?.name ?? 'Opponent'} 3-dart average`"
      ></dt>
      <dd
        class="font-bold"
        x-text={`(${summaryModel}?.guestThreeDartAverage ?? 0).toFixed(1)`}
      ></dd>
    </div>
    <div class="flex justify-between font-mono" x-show={hasGuestExpr} x-cloak>
      <dt
        class="text-text-muted"
        x-text="`${session?.settings.players.find((player) => player.type !== 'user')?.name ?? 'Opponent'} darts thrown`"
      ></dt>
      <dd class="font-bold" x-text={`String(${summaryModel}?.guestDartsThrown ?? 0)`}></dd>
    </div>
    <div class="flex justify-between font-mono" x-show={hasGuestExpr} x-cloak>
      <dt
        class="text-text-muted"
        x-text="`${session?.settings.players.find((player) => player.type !== 'user')?.name ?? 'Opponent'} checkouts`"
      ></dt>
      <dd class="font-bold" x-text={`String(${summaryModel}?.guestCheckouts ?? 0)`}></dd>
    </div>
  </dl>

  <div class="grid grid-cols-2 gap-3">
    <button
      type="button"
      class="btn-secondary btn-press font-medium flex items-center justify-center"
      @click="backToGames()"
    >
      Back
    </button>
    <button
      type="button"
      class="btn-primary btn-press"
      :disabled={persistingModel}
      @click="playAgain()"
    >
      Play again
    </button>
  </div>
</article>
