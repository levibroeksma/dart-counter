<div
  class="space-y-4"
  x-show="players.some((player) => player.type === 'dartbot')"
  x-cloak
>
  <label
    for="dartbot-level"
    class="section-label"
    >DartBot level <span
      class="text-foreground text-sm font-medium"
      x-text="dartbotLevel"
    ></span></label
  >
  <div class="space-y-4">
    <input
      id="dartbot-level"
      type="range"
      min="1"
      max="10"
      step="1"
      x-model.number="dartbotLevel"
      class="accent-primary w-full"
    />
    <dl
      class="border-border bg-popover grid grid-cols-1 gap-x-4 gap-y-1 rounded-md border px-3 py-2"
    >
      <div class="flex justify-between gap-2 text-xs">
        <dt class="text-muted-foreground">3-dart avg</dt>
        <dd
          class="text-foreground font-mono font-semibold"
          x-text="dartbotLevelPreview.threeDartAverage"
        >
        </dd>
      </div>
      <div class="flex justify-between gap-2 text-xs">
        <dt class="text-muted-foreground">Checkout rate</dt>
        <dd
          class="text-foreground font-mono font-semibold"
          x-text="dartbotLevelPreview.checkoutSuccessRate"
        >
        </dd>
      </div>
    </dl>
  </div>
</div>
