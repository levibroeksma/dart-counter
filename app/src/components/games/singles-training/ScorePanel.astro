---
interface Props {
  scoreModel?: string;
  segmentCountsModel?: string;
}

const {
  scoreModel = "session.state.score",
  segmentCountsModel = "session.state.segmentCounts",
} = Astro.props;
---

<article class="game-panel p-3 flex flex-col justify-center items-center h-fit gap-4">
  <div class="flex flex-col items-center justify-center gap-2 flex-1 w-full">
    <span class="text-4xl font-bold" x-text={scoreModel}>0</span>
    <span
      class="text-xs text-text-muted font-mono uppercase tracking-wider bg-slate-600/20 rounded-md px-2 py-1"
    >
      Current Score
    </span>
  </div>
  <div class="flex flex-col text-text-muted font-mono text-xs flex-1 w-full">
    <div class="inline-flex justify-between">
      <span>Miss</span>
      <span x-text={`${segmentCountsModel}.miss`}>0</span>
    </div>
    <div class="inline-flex justify-between">
      <span>Single</span>
      <span x-text={`${segmentCountsModel}.single`}>0</span>
    </div>
    <div class="inline-flex justify-between">
      <span>Double</span>
      <span x-text={`${segmentCountsModel}.double`}>0</span>
    </div>
    <div class="inline-flex justify-between">
      <span>Triple</span>
      <span x-text={`${segmentCountsModel}.triple`}>0</span>
    </div>
  </div>
</article>
