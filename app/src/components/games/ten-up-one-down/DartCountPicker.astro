---
interface Props {
  label: string;
  options: number[];
  model: string;
  onSelect: string;
}

const { label, options, model, onSelect } = Astro.props;
---

<div class="flex flex-col w-full gap-2">
  <h3 class="section-label">{label}</h3>
  <div class="flex items-center justify-center gap-2">
    {options.map((n) => (
      <div
        class="card-interactive btn-press justify-center text-sm text-center"
        @click={`${onSelect}(${n})`}
        :class={`${model} === ${n} ? 'bg-accent text-accent-foreground' : ''`}
        :aria-pressed={`${model} === ${n}`}
      >
        {n}
      </div>
    ))}
  </div>
</div>
